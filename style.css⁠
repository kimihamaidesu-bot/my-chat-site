body { margin: 0; font-family: sans-serif; background: #fffdf0; }
.app-container { display: flex; height: 100vh; }
.sidebar { width: 30%; background: #fff; border-right: 1px solid #eee; padding: 20px; }
.brand { font-weight: bold; color: #f9d77a; margin-bottom: 20px; }
.room-list { list-style: none; padding: 0; }
.room-list li { padding: 10px; cursor: pointer; border-radius: 8px; }
.room-list li.active { background: #fffbeb; color: #e6b800; }
.add-btn { width: 100%; margin-top: 20px; padding: 10px; background: #fdf6d0; border: none; border-radius: 10px; }
.chat-main { width: 70%; display: flex; flex-direction: column; }
.chat-header { padding: 20px; background: #fff; border-bottom: 1px solid #eee; }
.chat-messages { flex: 1; padding: 20px; overflow-y: auto; }
.chat-input-area { padding: 20px; display: flex; flex-direction: column; gap: 10px; }
.input-row { display: flex; gap: 10px; }
input { padding: 8px; border: 1px solid #ddd; border-radius: 10px; }
.send-btn { padding: 10px 20px; background: #f9d77a; border: none; border-radius: 20px; color: white; }
